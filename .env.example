# Environment variables for Merry Dashboard
# Copy this file to .env.local and fill in the values

# Database - Neon PostgreSQL
# Get your connection string from: https://neon.tech -> Project -> Connection Details
DATABASE_URL="postgresql://user:password@ep-xxx-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# NextAuth Configuration
# Generate secret: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key-here"

# Google OAuth (get from https://console.cloud.google.com/)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your-google-client-secret"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"