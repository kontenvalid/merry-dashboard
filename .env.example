# Merry Dashboard Environment Variables
# ========================================
# COPY THIS FILE TO .env.local AND FILL IN YOUR VALUES
# NEVER commit .env.local or any file containing real credentials!

# --- Composio MCP ---
# Get from: https://app.composio.com/settings/api-keys
# Your Composio workspace name from URL: dashboard.composio.dev/YOUR_WORKSPACE
COMPOSIO_WORKSPACE_NAME=your_workspace_name
COMPOSIO_API_KEY=your_composio_api_key_here

# --- Meta / Facebook Graph API ---
# Get from: https://developers.facebook.com
# Used for Meta Ads and Facebook Graph API access
META_TOKEN=your_meta_token_here

# --- Google OAuth ---
# Get from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID for web application
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- Google Sheets & Drive ---
# Optional: Spreadsheet ID for content schedule (from URL)
GOOGLE_SHEETS_ID=your_google_sheets_id
# Optional: Google Drive folder IDs for organized uploads
GOOGLE_DRIVE_CAROUSEL_FOLDER_ID=your_carousel_folder_id
GOOGLE_DRIVE_PARENT_ID=your_parent_folder_id

# --- NextAuth ---
# Generate random secret: openssl rand -base64 32
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=https://merry-dashboard.vercel.app

# --- Database - Neon PostgreSQL ---
# Get from: https://neon.tech
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
